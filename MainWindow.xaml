<Window x:Class="MarkDNext.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarkDNext"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="MarkDNext"
        Height="760"
        Width="1180"
        MinHeight="560"
        MinWidth="860"
        AllowDrop="True"
        Closing="Window_Closing"
        Drop="Window_Drop"
        KeyDown="Window_KeyDown"
        SourceInitialized="Window_SourceInitialized"
        Icon="Logo.png"
        Background="Transparent">
    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#EAF3F6" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#1F2933" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#EAF3F6" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#1F2933" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#DCEEFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1F2933" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FFFFFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#1F2933" />
        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#5D6978" />
    </Window.Resources>
    <DockPanel x:Name="RootDock" Background="#DDF6F7F9">
        <DockPanel.Resources>
            <SolidColorBrush x:Key="ThemeTextBrush" Color="#1F2933" />
            <SolidColorBrush x:Key="ThemeMutedBrush" Color="#5D6978" />
            <SolidColorBrush x:Key="ThemeLineBrush" Color="#D9E0E8" />
            <SolidColorBrush x:Key="ThemeSurfaceBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ThemeChromeBrush" Color="#EAF3F6" />
            <SolidColorBrush x:Key="ThemeMenuBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ThemeMenuBorderBrush" Color="#D9E0E8" />
            <SolidColorBrush x:Key="ThemeMenuHighlightBrush" Color="#DCEEFF" />
            <SolidColorBrush x:Key="ThemeSelectionBrush" Color="#DCEEFF" />
            <SolidColorBrush x:Key="ThemeScrollbarThumbBrush" Color="#B8C4D2" />
            <SolidColorBrush x:Key="ThemeScrollbarThumbHoverBrush" Color="#91A0B4" />

            <ControlTemplate x:Key="TopLevelMenuHeaderTemplate" TargetType="{x:Type MenuItem}">
                <Grid>
                    <Border x:Name="HeaderBorder"
                            Background="{DynamicResource ThemeChromeBrush}"
                            Padding="10,5">
                        <ContentPresenter ContentSource="Header"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <Popup x:Name="PART_Popup"
                           AllowsTransparency="True"
                           Focusable="False"
                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                           Placement="Bottom"
                           PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                           PopupAnimation="None">
                        <Border Background="{DynamicResource ThemeMenuBrush}"
                                BorderBrush="{DynamicResource ThemeMenuBorderBrush}"
                                BorderThickness="1"
                                MinWidth="220"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </Popup>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource ThemeMenuHighlightBrush}" />
                    </Trigger>
                    <Trigger Property="IsSubmenuOpen" Value="True">
                        <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource ThemeMenuHighlightBrush}" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="{DynamicResource ThemeMutedBrush}" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <ControlTemplate x:Key="TopLevelMenuItemTemplate" TargetType="{x:Type MenuItem}">
                <Border x:Name="HeaderBorder"
                        Background="{DynamicResource ThemeChromeBrush}"
                        Padding="10,5">
                    <ContentPresenter ContentSource="Header"
                                      RecognizesAccessKey="True"
                                      VerticalAlignment="Center"
                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource ThemeMenuHighlightBrush}" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="{DynamicResource ThemeMutedBrush}" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <ControlTemplate x:Key="SubmenuHeaderTemplate" TargetType="{x:Type MenuItem}">
                <Grid>
                    <Border x:Name="RowBackground"
                            Background="{DynamicResource ThemeMenuBrush}"
                            MinHeight="30"
                            SnapsToDevicePixels="True">
                        <Grid Margin="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="22" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CheckMark"
                                       Grid.Column="0"
                                       Text="✓"
                                       Visibility="Hidden"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}" />
                            <ContentPresenter Grid.Column="1"
                                              Margin="0,5,18,5"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                            <TextBlock Grid.Column="2"
                                       Margin="12,5,8,5"
                                       Text="{TemplateBinding InputGestureText}"
                                       Foreground="{DynamicResource ThemeMutedBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3"
                                       Text="›"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}" />
                        </Grid>
                    </Border>
                    <Popup x:Name="PART_Popup"
                           AllowsTransparency="True"
                           Focusable="False"
                           HorizontalOffset="-1"
                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                           Placement="Right"
                           PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                           PopupAnimation="None">
                        <Border Background="{DynamicResource ThemeMenuBrush}"
                                BorderBrush="{DynamicResource ThemeMenuBorderBrush}"
                                BorderThickness="1"
                                MinWidth="220"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </Popup>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter TargetName="RowBackground" Property="Background" Value="{DynamicResource ThemeMenuHighlightBrush}" />
                    </Trigger>
                    <Trigger Property="IsSubmenuOpen" Value="True">
                        <Setter TargetName="RowBackground" Property="Background" Value="{DynamicResource ThemeMenuHighlightBrush}" />
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="{DynamicResource ThemeMutedBrush}" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <ControlTemplate x:Key="SubmenuItemTemplate" TargetType="{x:Type MenuItem}">
                <Border x:Name="RowBackground"
                        Background="{DynamicResource ThemeMenuBrush}"
                        MinHeight="30"
                        SnapsToDevicePixels="True">
                    <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CheckMark"
                                   Grid.Column="0"
                                   Text="✓"
                                   Visibility="Hidden"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{TemplateBinding Foreground}" />
                        <ContentPresenter Grid.Column="1"
                                          Margin="0,5,18,5"
                                          ContentSource="Header"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                        <TextBlock Grid.Column="2"
                                   Margin="12,5,8,5"
                                   Text="{TemplateBinding InputGestureText}"
                                   Foreground="{DynamicResource ThemeMutedBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter TargetName="RowBackground" Property="Background" Value="{DynamicResource ThemeMenuHighlightBrush}" />
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="{DynamicResource ThemeMutedBrush}" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <Style TargetType="{x:Type MenuItem}">
                <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}" />
                <Setter Property="Background" Value="{DynamicResource ThemeMenuBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeMenuBorderBrush}" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Style.Triggers>
                    <Trigger Property="Role" Value="TopLevelHeader">
                        <Setter Property="Background" Value="{DynamicResource ThemeChromeBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ThemeChromeBrush}" />
                        <Setter Property="Template" Value="{StaticResource TopLevelMenuHeaderTemplate}" />
                    </Trigger>
                    <Trigger Property="Role" Value="TopLevelItem">
                        <Setter Property="Background" Value="{DynamicResource ThemeChromeBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ThemeChromeBrush}" />
                        <Setter Property="Template" Value="{StaticResource TopLevelMenuItemTemplate}" />
                    </Trigger>
                    <Trigger Property="Role" Value="SubmenuHeader">
                        <Setter Property="Template" Value="{StaticResource SubmenuHeaderTemplate}" />
                    </Trigger>
                    <Trigger Property="Role" Value="SubmenuItem">
                        <Setter Property="Template" Value="{StaticResource SubmenuItemTemplate}" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="{DynamicResource ThemeMutedBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type ContextMenu}">
                <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}" />
                <Setter Property="Background" Value="{DynamicResource ThemeMenuBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeMenuBorderBrush}" />
            </Style>

            <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="{x:Type Separator}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Separator}">
                            <Border Height="1"
                                    Margin="28,5,8,5"
                                    Background="{DynamicResource ThemeMenuBorderBrush}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ThemedComboBoxStyle" TargetType="{x:Type ComboBox}">
                <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}" />
                <Setter Property="Background" Value="{DynamicResource ThemeSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeLineBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="6,2" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ComboBox}">
                            <Grid SnapsToDevicePixels="True">
                                <ToggleButton x:Name="ToggleButton"
                                              ClickMode="Press"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                                            <Border x:Name="ToggleBorder"
                                                    Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="24" />
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter Grid.Column="0"
                                                                      Margin="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                      HorizontalAlignment="Stretch"
                                                                      VerticalAlignment="Center"
                                                                      Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                      ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                      ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                      RecognizesAccessKey="True" />
                                                    <Path Grid.Column="1"
                                                          Width="8"
                                                          Height="5"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Data="M 0 0 L 4 5 L 8 0 Z"
                                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ThemeMenuHighlightBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Bottom"
                                       PopupAnimation="None">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ScrollViewer CanContentScroll="True"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource ThemeMutedBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FlatScrollbarThumbStyle" TargetType="{x:Type Thumb}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Thumb}">
                            <Border Background="{TemplateBinding Background}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="{x:Type ScrollBar}">
                <Setter Property="Background" Value="{DynamicResource ThemeSurfaceBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ThemeScrollbarThumbBrush}" />
                <Setter Property="Width" Value="10" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid Background="{TemplateBinding Background}">
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="{x:Static ScrollBar.LineUpCommand}"
                                                      Opacity="0"
                                                      Focusable="False" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb x:Name="ScrollbarThumb"
                                               Style="{StaticResource FlatScrollbarThumbStyle}"
                                               Background="{DynamicResource ThemeScrollbarThumbBrush}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="{x:Static ScrollBar.LineDownCommand}"
                                                      Opacity="0"
                                                      Focusable="False" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter Property="Height" Value="10" />
                                    <Setter Property="Width" Value="Auto" />
                                    <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                                </Trigger>
                                <Trigger SourceName="ScrollbarThumb" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ScrollbarThumb" Property="Background" Value="{DynamicResource ThemeScrollbarThumbHoverBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </DockPanel.Resources>
        <Menu x:Name="MainMenu"
              DockPanel.Dock="Top"
              Background="#EAF3F6FA"
              Visibility="Collapsed"
              LostKeyboardFocus="MainMenu_LostKeyboardFocus">
            <MenuItem Header="_File">
                <MenuItem Header="_New" InputGestureText="Ctrl+N" Click="New_Click" />
                <MenuItem Header="_Open..." InputGestureText="Ctrl+O" Click="Open_Click" />
                <Separator />
                <MenuItem Header="_Save" InputGestureText="Ctrl+S" Click="Save_Click" />
                <MenuItem Header="Save _As..." InputGestureText="Ctrl+Shift+S" Click="SaveAs_Click" />
                <MenuItem Header="_Reload From Disk" InputGestureText="F5" Click="Reload_Click" />
                <Separator />
                <MenuItem Header="_Print..." InputGestureText="Ctrl+P" Click="Print_Click" />
                <MenuItem Header="_Export">
                    <MenuItem Header="_HTML..." Click="ExportHtml_Click" />
                    <MenuItem Header="_PDF..." Click="ExportPdf_Click" />
                </MenuItem>
                <Separator />
                <MenuItem Header="_Close Window" InputGestureText="Ctrl+W" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGestureText="Ctrl+Z" Click="Undo_Click" />
                <MenuItem Header="_Redo" InputGestureText="Ctrl+Y" Click="Redo_Click" />
                <Separator />
                <MenuItem Header="Cu_t" InputGestureText="Ctrl+X" Click="Cut_Click" />
                <MenuItem Header="_Copy" InputGestureText="Ctrl+C" Click="Copy_Click" />
                <MenuItem Header="_Paste" InputGestureText="Ctrl+V" Click="Paste_Click" />
                <Separator />
                <MenuItem Header="_Find..." InputGestureText="Ctrl+F" Click="Find_Click" />
                <MenuItem Header="Find _Next" InputGestureText="F3" Click="FindNext_Click" />
                <MenuItem Header="Find _Previous" InputGestureText="Shift+F3" Click="FindPrevious_Click" />
                <MenuItem Header="Insert _Image..." Click="InsertImage_Click" />
                <Separator />
                <MenuItem x:Name="AutoCompletionMenuItem" Header="_Automatic Completion" InputGestureText="Ctrl+H" IsCheckable="True" Click="AutoCompletion_Click" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="WysiwygModeMenuItem" Header="_WYSIWYG" IsCheckable="True" Click="WysiwygMode_Click" />
                <MenuItem x:Name="ViewBothMenuItem" Header="_Split View" IsCheckable="True" IsChecked="True" Click="SplitMode_Click" />
                <MenuItem x:Name="ViewPreviewMenuItem" Header="_Preview Only" IsCheckable="True" Click="PreviewMode_Click" />
                <MenuItem x:Name="HideMenuBarMenuItem" Header="_Hide Menu Bar" IsCheckable="True" Click="HideMenuBar_Click" />
                <Separator />
                <MenuItem x:Name="WordWrapMenuItem" Header="_Word Wrap" IsCheckable="True" IsChecked="True" Click="WordWrap_Click" />
                <Separator />
                <MenuItem Header="_Font">
                    <MenuItem Header="_Choose Font..." Click="Font_Click" />
                    <MenuItem Header="Increase Font Size" InputGestureText="Ctrl++" Click="IncreaseFont_Click" />
                    <MenuItem Header="Decrease Font Size" InputGestureText="Ctrl+-" Click="DecreaseFont_Click" />
                    <MenuItem Header="_Reset Font" Click="ResetFont_Click" />
                </MenuItem>
                <MenuItem Header="_Themes">
                    <MenuItem Header="_Choose Theme..." Click="ChooseTheme_Click" />
                    <Separator />
                    <MenuItem x:Name="NormalThemeModeMenuItem" Header="_Normal Mode" IsCheckable="True" IsChecked="True" Click="NormalThemeMode_Click" />
                    <MenuItem x:Name="DarkThemeModeMenuItem" Header="_Dark Mode" IsCheckable="True" Click="DarkThemeMode_Click" />
                </MenuItem>
                <MenuItem Header="_Color Profile">
                    <MenuItem Header="_Load..." Click="LoadColorProfile_Click" />
                    <MenuItem Header="_Save Current As..." Click="SaveColorProfile_Click" />
                    <MenuItem Header="_Reset Colors" Click="ResetColorProfile_Click" />
                </MenuItem>
                <Separator />
                <MenuItem Header="_Window Material">
                    <MenuItem x:Name="MicaMaterialMenuItem" Header="_Mica" IsCheckable="True" Click="MicaMaterial_Click" />
                    <MenuItem x:Name="AcrylicMaterialMenuItem" Header="_Acrylic" IsCheckable="True" Click="AcrylicMaterial_Click" />
                    <MenuItem x:Name="FlatMaterialMenuItem" Header="_Flat" IsCheckable="True" IsChecked="True" Click="FlatMaterial_Click" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click" />
            </MenuItem>
        </Menu>

        <Border x:Name="FindBar"
                DockPanel.Dock="Top"
                Visibility="Collapsed"
                BorderBrush="#BFC8D4"
                BorderThickness="0,1,0,1"
                Background="#F7FFFFFF"
                Padding="8">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Find"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#485364" />
                <TextBox x:Name="FindTextBox"
                         Width="280"
                         MinWidth="180"
                         VerticalContentAlignment="Center"
                         KeyDown="FindTextBox_KeyDown" />
                <Button Content="Next" MinWidth="58" Margin="8,0,0,0" Click="FindNext_Click" />
                <Button Content="Prev" MinWidth="58" Margin="6,0,0,0" Click="FindPrevious_Click" />
                <Button Content="Close" MinWidth="62" Margin="6,0,0,0" Click="CloseFind_Click" />
            </DockPanel>
        </Border>

        <StatusBar x:Name="MainStatusBar" DockPanel.Dock="Bottom" Background="#EAF3F6FA">
            <StatusBarItem Padding="0" HorizontalContentAlignment="Stretch">
                <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=StatusBar}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PositionText"
                               Grid.Column="0"
                               Margin="8,0,12,0"
                               VerticalAlignment="Center"
                               Text="Ln 1, Col 1" />
                    <TextBlock x:Name="StatusText"
                               Grid.Column="2"
                               Margin="12,0,6,0"
                               MaxWidth="560"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Text="Ready"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel Grid.Column="3"
                                x:Name="StatusViewButtons"
                                Orientation="Horizontal"
                                Margin="4,0,10,0"
                                VerticalAlignment="Center">
                        <ToggleButton x:Name="StatusEditorModeButton"
                                      Width="24"
                                      Height="22"
                                      Margin="0,0,3,0"
                                      ToolTip="Editor only"
                                      Click="StatusEditorMode_Click">
                            <Grid Width="13" Height="13">
                                <Border BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                        BorderThickness="1" />
                                <Rectangle Width="3"
                                           Margin="2,2,0,2"
                                           HorizontalAlignment="Left"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                            </Grid>
                        </ToggleButton>
                        <ToggleButton x:Name="StatusSplitModeButton"
                                      Width="24"
                                      Height="22"
                                      Margin="0,0,3,0"
                                      ToolTip="Split view"
                                      Click="StatusSplitMode_Click">
                            <Grid Width="13" Height="13">
                                <Border BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                        BorderThickness="1" />
                                <Rectangle Width="1"
                                           HorizontalAlignment="Center"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                            </Grid>
                        </ToggleButton>
                        <ToggleButton x:Name="StatusPreviewModeButton"
                                      Width="24"
                                      Height="22"
                                      ToolTip="Preview only"
                                      Click="StatusPreviewMode_Click">
                            <Grid Width="13" Height="13">
                                <Border BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                        BorderThickness="1" />
                                <Rectangle Height="3"
                                           Margin="2,2,2,0"
                                           VerticalAlignment="Top"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                            </Grid>
                        </ToggleButton>
                    </StackPanel>
                </Grid>
            </StatusBarItem>
        </StatusBar>

        <Grid x:Name="WorkspaceGrid" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="EditorColumn" Width="*" MinWidth="220" />
                <ColumnDefinition x:Name="SplitterColumn" Width="6" />
                <ColumnDefinition x:Name="PreviewColumn" Width="*" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <Border x:Name="EditorPane"
                    Grid.Column="0"
                    BorderBrush="#BFC8D4"
                    BorderThickness="1"
                    Background="#F7FFFFFF">
                <Grid>
                    <avalon:TextEditor x:Name="Editor"
                                       FontFamily="Consolas"
                                       FontSize="18"
                                       Background="#00FFFFFF"
                                       Foreground="#182433"
                                       BorderThickness="0"
                                       Padding="14"
                                       ShowLineNumbers="True"
                                       WordWrap="True"
                                       TextChanged="Editor_TextChanged" />
                    <wv2:WebView2 x:Name="Wysiwyg"
                                  Visibility="Collapsed" />
                </Grid>
            </Border>

            <GridSplitter x:Name="Splitter"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#B8C4D2"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns" />

            <Border x:Name="PreviewPane"
                    Grid.Column="2"
                    BorderBrush="#BFC8D4"
                    BorderThickness="1"
                    Background="#F7FFFFFF">
                <wv2:WebView2 x:Name="Preview" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
